# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Admin user's Telegram user ID (chat ID), not username
# Send /start to @userinfobot on Telegram to get your user ID
ADMIN_USER_ID=123456789

# Limits
MAX_FILE_SIZE_GB=4
MAX_DAILY_DOWNLOADS_PER_USER=10
MAX_CONCURRENT_QUEUED_PER_USER=3
GLOBAL_RATE_LIMIT_PER_MINUTE=50
MAX_RESOLUTION=1080
DEFAULT_FORMAT=mp4
ALLOWED_FORMATS=mp4,mkv,mp3,m4a
FORCE_H264=true

# Optimization
AUTO_OPTIMIZE=true
OPTIMIZATION_PRESET=medium
VIDEO_BITRATE_MBPS=4
AUDIO_BITRATE_KBPS=128
MAX_OPTIMIZATION_TIME_SECONDS=600
ENABLE_4K_BLOCKING=true

# Paths
DOWNLOAD_PATH=./downloads/temp/
OPTIMIZED_PATH=./downloads/optimized/
LOG_PATH=./logs/
DB_PATH=./database/bot.db

# FFmpeg & yt-dlp
FFMPEG_PATH=ffmpeg
YTDLP_PATH=yt-dlp

# Features
ENABLE_ANALYTICS=true
ENABLE_PLAYLIST_SUPPORT=true
ENABLE_THUMBNAIL_EXTRACTION=true
